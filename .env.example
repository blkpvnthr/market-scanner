# Opportunity Engine — example environment.
# Copy to .env (git-ignored) and fill in. Everything is OPTIONAL: with no keys
# the engine runs on the deterministic mock provider.
# Research only. Not financial advice.

# --- Live data providers (optional) ---
OE_PROVIDER=mock          # mock | auto | yahoo | finnhub | alpha_vantage | alpaca
APCA_API_KEY=
APCA_SECRET_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- Scan tuning (optional) ---
# OE_WATCHLIST=NVDA,AMD,ASML,RKLB
# OE_TOP_N=20
# OE_OUTPUT_DIR=reports_out
# OE_SEED=7

# --- Email delivery (required only for the `email` command / serverless) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password   # Gmail: use an App Password, not your login
EMAIL_FROM=you@example.com
EMAIL_TO=contact@quantumquant.trade
EMAIL_TOP_N=25                    # emailed report size (clamped to >= 20)
# SMTP_STARTTLS=true
